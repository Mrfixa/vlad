APP_NAME=Vito
APP_ENV=production
APP_MODE=live
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vito
DB_USERNAME=root
DB_PASSWORD=

# Use 'database' or 'redis' in production — never 'sync'
BROADCAST_DRIVER=reverb
# Use 'redis' for CACHE_DRIVER/SESSION_DRIVER when running multiple app servers — 'file' is per-node only.
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
# Ride-timeout auto-cancel needs 'redis' + a running `php artisan queue:work` (or Supervisor).
# 'database'/'file'/'sync' will silently drop that job in production.
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Comma-separated web origins allowed to call /api/* from a browser (empty = deny all cross-origin).
# Mobile apps use bearer tokens and are unaffected. e.g. https://admin.your-domain.com
CORS_ALLOWED_ORIGINS=

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# SMTP — required for driver approval emails, password resets, etc.
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# S3 — leave blank to use local disk storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Reverb WebSocket server — runs on same box, proxied through Nginx on port 6015.
# Generate your own IDs/keys in production (e.g. `php -r "echo bin2hex(random_bytes(16));"`).
# REVERB_HOST must point to your actual domain; REVERB_SCHEME must be 'https' in production.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=your-domain.com
REVERB_PORT=6015
REVERB_SCHEME=https
REVERB_SSL_CERT_PATH=
REVERB_SSL_KEY_PATH=

# Pusher mirrors Reverb — keep IDs/keys in sync with REVERB_* values.
# PUSHER_APP_SECRET must match REVERB_APP_SECRET.
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=your-domain.com
PUSHER_PORT=6015
PUSHER_SCHEME=https

MIX_APP_NAME="${APP_NAME}"
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_HOST="${PUSHER_HOST}"
MIX_PUSHER_PORT="${PUSHER_PORT}"
MIX_PUSHER_SCHEME="${PUSHER_SCHEME}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

MIX_REVERB_APP_KEY="${REVERB_APP_KEY}"
MIX_REVERB_HOST="${REVERB_HOST}"
MIX_REVERB_PORT="${REVERB_PORT}"
MIX_REVERB_SCHEME="${REVERB_SCHEME}"

# Sentry error tracking (optional — no-op if not set)
SENTRY_LARAVEL_DSN=
# Fraction of errors captured (defaults to 1.0 = 100% if unset). Lower it in high-traffic prod.
SENTRY_SAMPLE_RATE=1.0
# Fraction of transactions traced for performance (leave empty to disable tracing).
SENTRY_TRACES_SAMPLE_RATE=

# Structured JSON logging — set LOG_CHANNEL=json_stderr for ELK/Datadog ingestion
# LOG_CHANNEL=json_stderr

# Stripe payment keys — configure via Admin panel settings, but you can set these as env overrides
STRIPE_PUBLIC_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ----------------------------------------------------------------------------
# Localization & app behaviour
# ----------------------------------------------------------------------------
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
# Displayed on the admin login screen
SOFTWARE_VERSION=2.39.0
# Bcrypt cost factor for password/PIN hashing
BCRYPT_ROUNDS=12

# ----------------------------------------------------------------------------
# Laravel Passport (API OAuth) — generated by `php artisan passport:keys --force`
# and `php artisan passport:client --personal`. Leave blank to use the key files.
# Token expiry defaults: 30-day access, 60-day refresh, 6-month personal.
# Override per environment with PASSPORT_TOKEN_EXPIRY_DAYS, PASSPORT_REFRESH_EXPIRY_DAYS,
# and PASSPORT_PERSONAL_TOKEN_EXPIRY_MONTHS.
# ----------------------------------------------------------------------------
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=
# PASSPORT_TOKEN_EXPIRY_DAYS=30
# PASSPORT_REFRESH_EXPIRY_DAYS=60
# PASSPORT_PERSONAL_TOKEN_EXPIRY_MONTHS=6

# ----------------------------------------------------------------------------
# SMS gateway (Twilio) — used for phone OTP where enabled
# ----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ----------------------------------------------------------------------------
# Additional payment gateways (optional — configure those you use)
# ----------------------------------------------------------------------------
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PAYMENT_URL=https://api.paystack.co
MERCHANT_EMAIL=

PAYTM_MERCHANT_KEY=
PAYTM_MERCHANT_MID=
PAYTM_MERCHANT_WEBSITE=
PAYTM_REFUND_URL=
PAYTM_STATUS_QUERY_URL=
PAYTM_STATUS_QUERY_NEW_URL=
PAYTM_TXN_URL=

# ----------------------------------------------------------------------------
# Error tracking (optional)
# ----------------------------------------------------------------------------
SENTRY_DSN=

# ----------------------------------------------------------------------------
# Flutter build-time keys (NOT backend env vars).
# Passed to the apps at build time via --dart-define and stored as CI secrets:
#   flutter build apk --release \
#     --dart-define=MAPS_API_KEY=<google-maps-key> \
#     --dart-define=STRIPE_PUBLISHABLE_KEY=<stripe-pk>
# MAPS_API_KEY=
# STRIPE_PUBLISHABLE_KEY=

# ----------------------------------------------------------------------------
# Seeded credentials (created by `php artisan db:seed`).
# In production (APP_ENV=production) the admin account is only created when
# ADMIN_SEED_EMAIL and ADMIN_SEED_PASSWORD are both set.
# Customer/driver demo accounts (username: customer/driver, PIN: 123456) are also
# skipped in production unless SEED_DEMO_USERS=true.
# ----------------------------------------------------------------------------
# ADMIN_SEED_EMAIL=admin@your-domain.com
# ADMIN_SEED_PASSWORD=your-secure-password
# SEED_DEMO_USERS=false

